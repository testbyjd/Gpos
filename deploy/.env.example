# Production overrides for deploy/install.sh (optional).
# The installer writes backend/.env automatically — this file is just a reference.

DOMAIN=gondaltrader.com
APP_DIR=/opt/gpos

# Leave empty to auto-generate a strong password.
DB_PASSWORD=

# Certbot Let's Encrypt email (required for HTTPS during install).
CERTBOT_EMAIL=
RUN_CERTBOT=1
